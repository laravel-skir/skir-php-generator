{
  "name": "skir-php-generator",
  "version": "0.1.0",
  "description": "Skir code generator for standard PHP data objects.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Maxim Kerstens",
    "email": "maxim.kerstens@gmail.com"
  },
  "homepage": "https://github.com/php-skir/skir-php-generator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/php-skir/skir-php-generator.git"
  },
  "bugs": {
    "url": "https://github.com/php-skir/skir-php-generator/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "php",
    "rpc",
    "skir",
    "skir-generator"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "skir-php-generator": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run --cache .npm-cache",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:coverage": "npm run build && vitest run --coverage --coverage.reporter=text --coverage.reporter=json-summary --coverage.include=src/**/*.ts --coverage.thresholds.lines=80 --coverage.thresholds.statements=80 --coverage.thresholds.branches=75 --coverage.thresholds.functions=75",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "skir-internal": "^0.2.21",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "skir": "^1.2.19",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
